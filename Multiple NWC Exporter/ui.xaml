<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NWC Export Tool"
        Height="650"
        Width="420"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Export Path -->
        <StackPanel>
            <TextBlock Text="Export Folder"/>
            <TextBox x:Name="PathBox" Margin="0,5"/>
            <Button Content="Browse" Click="browse_folder"/>
        </StackPanel>

        <!-- View Selection -->
        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="Select 3D View"/>
            <ComboBox x:Name="ViewCombo"
                      Height="25"
                      DisplayMemberPath="Name"/>
        </StackPanel>

        <!-- NWC Setup -->
        <GroupBox Header="NWC Setup" Grid.Row="2" Margin="0,10">
            <StackPanel>
                <TextBlock Text="NWC Name"/>
                <TextBox x:Name="NwcNameBox"/>

                <TextBlock Text="Select Worksets" Margin="0,10,0,5"/>
                <ScrollViewer Height="200">
                    <StackPanel x:Name="WorksetPanel"/>
                </ScrollViewer>

                <Button Content="+ Add NWC"
                        Margin="0,10"
                        Click="add_nwc"/>

                <!-- SUMMARY LIST -->
                <TextBlock Text="Added NWC Definitions"
                           Margin="0,10,0,5"
                           FontWeight="Bold"/>

                <ListBox x:Name="NwcSummaryList"
                         Height="150"/>
            </StackPanel>
        </GroupBox>

        <!-- Submit -->
        <Button Content="Submit"
                Grid.Row="3"
                Height="30"
                Click="submit"/>
    </Grid>
</Window>
